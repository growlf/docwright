# Secrets and credentials
*.key
*.pem
credentials*
secrets*
.env
.env.*
!.env.example

# Temp files
/tmp/*

# Plugins are vault content, not repo content. Never commit dev plugin dirs/symlinks
# into the source tree (a committed symlink into a dev home dangles in every clone and
# 500s /api/plugins). Real plugins live in a vault's plugins/ dir.
/plugins/

# OS files
.DS_Store
Thumbs.db

# IDE (shared settings tracked, personal state ignored)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Obsidian vault artifacts
.obsidian/*
!.obsidian/community-plugins.json
!.obsidian/plugins
!.obsidian/plugins/templater-obsidian
!.obsidian/plugins/quickadd
.obsidian/plugins/*
!.obsidian/plugins/templater-obsidian/*
!.obsidian/plugins/quickadd/*

# Python cache and byte-code
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Virtual environments
.venv/
venv/

# Node
node_modules/

# Build artifacts
dist/
build/
.svelte-kit/
*.log

# policies/*/check.js are intentionally committed even though they are
# generated by `npm run build:atoms` (esbuild output from check.ts).
# They must be committed so adopted vaults can receive self-contained atom
# check files without requiring a build step. Run `npm run build:atoms`
# after editing any policies/*/check.ts file to regenerate.

# Extension package
*.vsix

# docwright derived cache (per-user)
.docworkbench/index.json
.docwright/index.json

# docwright backlinks cache (per-user)
.docworkbench/_backlinks.json
.docwright/_backlinks.json

# docwright daemon trust config (per-instance)
.docworkbench/daemon.json
.docwright/daemon.json

# docwright executor runtime state (transient — never commit)
.docwright/executor-checkpoints/
.docwright/executor-locks/

# docwright MCP audit log (transient test/runtime output — never commit).
# **/ so it also covers test fixture vaults (test/**/.docwright/audit.jsonl),
# which were being committed with test-run entries (#95).
**/.docwright/audit.jsonl
**/.docworkbench/audit.jsonl

# Phase 0 spike — throwaway code
spike/

# Source maps
*.js.map
.logs/
session-ses_*.md

# DocWright — managed entries (added by adopt-vault.ts)
# NOTE: skill/agent bridge dirs (.claude/skills/, .opencode/skills/, .gemini/)
# are canonical SOURCE in this repo and must stay tracked — adopt-vault.ts
# only ignores them in adopted downstream vaults, never here.
.dw-session.json
