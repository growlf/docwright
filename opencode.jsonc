{
  "$schema": "https://opencode.ai/config.json",
  "model": "auto-sync-from-ollama",
  "instructions": [
    "AGENTS.md",
    ".opencode/rules/commit-format.md",
    ".opencode/rules/frontmatter-validate.md",
    ".opencode/rules/no-plaintext-creds.md",
    ".opencode/rules/no-secrets.md",
    ".opencode/rules/no-work-before-approval.md",
    ".opencode/rules/hook-failure-feedback.md"
  ],
  "permission": {
    "edit": "ask",
    "write": "ask",
    "bash": "ask"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/sync-ollama-model.js",
            "timeout": 5,
            "statusMessage": "Syncing Ollama model..."
          }
        ]
      }
    ]
  },
  "server": {
    "hostname": "127.0.0.1"
  },
  "skills": {
    "paths": [".opencode/skills"]
  },
  "mcp": {
    "dw-mcp": {
      "type": "local",
      "command": [".venv/bin/python3", "scripts/mcp-server.py"]
    }
  },
  "agent": {
    "design": {
      "mode": "primary",
      "description": "Plan mode — can edit plans, proposals, docs, and profile definitions",
      "color": "#8B5CF6",
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": "ask",
        "read": "allow"
      },
      "prompt": "You are in design mode — a hybrid between plan and build. Your primary role is to analyze, plan, and propose like plan mode, but you are permitted to make edits to plan files (plans/*.md), proposal files (proposals/*.md), profile definitions (.docworkbench/*/), and documentation (docs/*.md). For other files, operate in a planning-only capacity and do not make direct edits. Always think before acting and explain your reasoning.\n\nLIFECYCLE ENFORCEMENT — lifecycle state transitions MUST use the MCP server's transition_to_* tools, not direct file edits. Never set approved: true on any proposal — only humans do that. The pre-commit hook will reject commits that violate lifecycle rules."
    }
  }
}
