# BMS AI Cluster — User Identity File
# Copy this to .env and fill in your details.
# This file is gitignored — your info stays local to your checkout.
#
# Used for tagging proposals, plans, and docs with accountability.
# Machine identity is ALWAYS from $(hostname), never user-supplied.

OPCODE_USER_NAME="Your Full Name"
OPCODE_USER_EMAIL="your.email@example.com"
OPCODE_USER_CONTACT="optional: matrix/signal/discord/phone"
