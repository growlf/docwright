# DocWright — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is safe to commit.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your details
#   docker compose up        # docker reads .env automatically
#   DocWright --docker       # launcher script also reads .env

# ── AI agent identity (used by OpenCode and MCP server) ──────────────────────
# Machine identity is always $(hostname) — never set it here.
OPCODE_USER_NAME="Your Name"
OPCODE_USER_EMAIL="you@example.com"
OPCODE_USER_CONTACT="your-github-handle"

# ── AI gateway ────────────────────────────────────────────────────────────────
# All AI calls (plan-review, apply-review, synthesize, chat, plan execution)
# route through OpenCode. Set OPENCODE_URL to wherever opencode serve is running.
OPENCODE_URL=http://localhost:4096

# Optional: API key for your preferred AI provider.
# OpenCode auto-detects ANTHROPIC_API_KEY and makes Claude models available
# in its model picker. The launcher (scripts/DocWright) exports this into
# OpenCode's environment automatically when src/webui/.env is present.
ANTHROPIC_API_KEY=

# Optional: pin which model plan-review, apply-review, and synthesize use.
# Format: "providerID/modelID" (e.g. "anthropic/claude-haiku-4-5-20251001")
# or bare "modelID". If unset, those routes follow OpenCode's active model.
OPENCODE_DEFAULT_MODEL=

# ── DocWright paths — required for vault portability ────────────────────────
# DOCWRIGHT_PATH: absolute path to the DocWright tool installation (where
# dist/mcp/server.js lives). Required by .mcp.json and opencode.json.
DOCWRIGHT_PATH="/path/to/docwright"

# DOCWRIGHT_VAULT_ROOT: absolute path to the vault being managed.
# In vault mode, this is the root of the markdown repo being governed.
# When managing DocWright itself, set this to the same as DOCWRIGHT_PATH.
DOCWRIGHT_VAULT_ROOT="/path/to/your/vault"

# ── Docker / docker compose ───────────────────────────────────────────────────
# Git identity used for commits made via the Web UI inside the container.
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="you@example.com"

# Personal access token for HTTPS git push (GitHub, Forgejo, Gitea).
# Leave empty to use SSH key auth instead (recommended for production).
# Mount your SSH key at /root/.ssh/id_ed25519 as an alternative.
GIT_TOKEN=""

# Absolute path to the vault (markdown repo) to mount into the container.
# For developing DocWright itself, point this at the repo root.
# For managing a separate vault, point it at that repo.
VAULT_PATH="/path/to/your/vault"

# Web UI port (default: 5173)
PORT=5173

# MCP SSE port — internal to the container, not exposed by default
MCP_PORT=3002

# ── Authentication ────────────────────────────────────────────────────────────
# AUTH_MODE controls which auth provider is active.
#   none    — no authentication (single-user local dev, default)
#   local   — username + password from LOCAL_AUTH_USER / LOCAL_AUTH_PASSWORD
#   forgejo — Forgejo OAuth (recommended for shared deployments)
AUTH_MODE=none

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
# Required when AUTH_MODE != none.
SESSION_SECRET=""

# Session TTL in seconds (default: 86400 = 24 hours).
SESSION_TTL_SECONDS=86400

# ── Forgejo OAuth (AUTH_MODE=forgejo) ─────────────────────────────────────────
# Base URL of your Forgejo instance (no trailing slash).
FORGEJO_URL="https://git.example.com"

# OAuth application credentials — create at:
# Forgejo → Settings → Applications → Manage OAuth2 Applications
# Redirect URI must be: https://<your-docwright-host>/auth/callback
FORGEJO_CLIENT_ID=""
FORGEJO_CLIENT_SECRET=""

# ── Local auth (AUTH_MODE=local) ──────────────────────────────────────────────
# Single admin account for air-gapped or personal deployments.
LOCAL_AUTH_USER=admin
# LOCAL_AUTH_PASSWORD must be a bcrypt hash. Generate with:
#   node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
LOCAL_AUTH_PASSWORD=""
LOCAL_AUTH_EMAIL="admin@localhost"
LOCAL_AUTH_DISPLAY_NAME="Admin"
