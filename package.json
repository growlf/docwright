{
  "name": "docwright",
  "displayName": "docwright",
  "description": "Organizational operating system for policy-driven teams",
  "version": "0.4.0",
  "license": "MIT",
  "publisher": "growlf",
  "repository": {
    "type": "git",
    "url": "https://github.com/growlf/docwright.git"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "commands": []
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "compile:mcp": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start:mcp": "node dist/mcp/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "sync:skills": "tsx scripts/sync-claude-skills.ts",
    "build:atoms": "npx tsx scripts/build-atoms.ts",
    "atoms:check": "npx tsx scripts/check-vault-atoms.ts",
    "test:atoms": "mocha --require tsx/cjs 'test/policy-atoms-core/**/*.test.ts'",
    "atoms:isolation": "npx tsx scripts/check-atom-isolation.ts",
    "test:dispatch": "mocha --require tsx/cjs 'test/dispatch/**/*.test.ts'",
    "test:executor": "mocha --require tsx/cjs 'test/executor/**/*.test.ts'",
    "test:mcp": "mocha --require tsx/cjs test/mcp/config.test.ts && mocha --require tsx/cjs test/mcp/mutation.test.ts && mocha --require tsx/cjs test/mcp/transitions.test.ts && mocha --require tsx/cjs test/mcp/query_utility.test.ts && mocha --require tsx/cjs test/mcp/parity.test.ts",
    "test:hooks:pending": "node test/hooks/test-pending-steps.js",
    "test:hooks": "bash test/hooks/test-lifecycle-hook.sh && bash test/hooks/test-research-hook.sh",
    "test:compat": "mocha --require tsx/cjs 'test/compat/**/*.test.ts'",
    "test:integration": "mocha --require tsx/cjs 'test/integration/**/*.test.ts'",
    "test": "npm run test:atoms && npm run atoms:isolation && npm run test:dispatch && npm run test:executor && npm run test:mcp && npm run test:hooks:pending && npm run test:hooks && npm run test:compat && npm run test:integration",
    "hook:install": "bash scripts/install-hooks.sh",
    "init": "npx tsx scripts/init.ts",
    "open": "npx tsx scripts/open-vault.ts",
    "adopt": "npx tsx scripts/adopt-vault.ts",
    "migrate:plan-steps": "npx tsx scripts/migrate-plan-steps.ts",
    "migrate:mode-field": "npx tsx scripts/migrate-mode-field.ts",
    "vault:migrate": "npx tsx scripts/vault-migrate.ts",
    "lifecycle:fix-approvals": "npx tsx scripts/fix-stale-approvals.ts",
    "lifecycle:fix-approvals:fix": "npx tsx scripts/fix-stale-approvals.ts --fix",
    "phase:close": "npx tsx scripts/phase-close.ts",
    "release:tag": "bash scripts/release-tag.sh",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile",
    "test:webui": "mocha --require tsx/cjs test/webui/**/*.test.ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.0.0",
    "mocha": "^10.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.15.13",
    "js-yaml": "^4.2.0"
  },
  "overrides": {
    "minimatch": ">=9.0.7",
    "serialize-javascript": ">=7.0.5"
  }
}
