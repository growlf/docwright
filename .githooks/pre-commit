#!/bin/bash
# =============================================================================
# DocWright - Pre-Commit Hook (slim)
# =============================================================================
# Validates:
# 1. Identity resolution + network (cached in /tmp/)
# 2. Frontmatter integrity (all lifecycle directories)
# 3. assigned_to field (BLOCK empty for approved/in-progress plans)
# 4. Automated field (enum: off|guided|full)
# 5. Template variable check
# 6. Scenario synthesis for automation plans
# 7. Agent Instructions section validation
#
# NOTE: Commit message format is validated by the commit-msg hook, not here.
# Pre-commit runs before git writes the message to COMMIT_EDITMSG, so reading
# that file here would validate the *previous* commit's message.
# =============================================================================

REPO_ROOT="$(git rev-parse --show-toplevel)" && cd "$REPO_ROOT" || exit 1

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
print_error()   { echo -e "${RED}[✗]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[!]${NC} $1"; }
print_status()  { echo -e "${GREEN}[✓]${NC} $1"; }

# =============================================================================
# 1. Identity + Network (cached in /tmp/)
# =============================================================================
resolve_identity() {
    local CACHE_FILE="/tmp/opencode-identity-cache"
    if [ -f "$CACHE_FILE" ] && [ "$(( $(date +%s) - $(stat -c %Y "$CACHE_FILE") ))" -lt 3600 ]; then
        cat "$CACHE_FILE"; return
    fi
    local ENV_FILE="$REPO_ROOT/.env" HOST=$(hostname) NAME="" EMAIL="" HAS_ISSUES=0
    [ -f "$ENV_FILE" ] && NAME=$(grep "^OPCODE_USER_NAME=" "$ENV_FILE" | cut -d= -f2- | tr -d '"' | xargs)
    [ -f "$ENV_FILE" ] && EMAIL=$(grep "^OPCODE_USER_EMAIL=" "$ENV_FILE" | cut -d= -f2- | tr -d '"' | xargs)
    local GIT_NAME=$(git config user.name 2>/dev/null || echo "")
    local GIT_EMAIL=$(git config user.email 2>/dev/null || echo "")
    [ -z "$NAME" ] || [ "$NAME" = "Your Full Name" ] && NAME="$GIT_NAME" && HAS_ISSUES=1
    [ -z "$EMAIL" ] && EMAIL="$GIT_EMAIL" && HAS_ISSUES=1
    [ -n "$GIT_NAME" ] && [ -n "$NAME" ] && [ "$GIT_NAME" != "$NAME" ] && echo "WARN .env user ($NAME) != git config ($GIT_NAME)" && HAS_ISSUES=1
    [ -n "$GIT_EMAIL" ] && [ -n "$EMAIL" ] && [ "$GIT_EMAIL" != "$EMAIL" ] && echo "WARN .env email ($EMAIL) != git config ($GIT_EMAIL)" && HAS_ISSUES=1
    local MSG="Human: $NAME ($EMAIL) | Machine: $HOST"
    [ $HAS_ISSUES -ne 0 ] && MSG="$MSG (has issues)"
    echo "$MSG" | tee "$CACHE_FILE"
}

detect_network() {
    local CACHE_FILE="/tmp/opencode-network-cache"
    if [ -f "$CACHE_FILE" ] && [ "$(( $(date +%s) - $(stat -c %Y "$CACHE_FILE") ))" -lt 3600 ]; then
        cat "$CACHE_FILE"; return
    fi
    local GATEWAY=$(ip route show default | awk '{print $3}' 2>/dev/null)
    local IFACE=$(ip route show default | awk '{print $5}' 2>/dev/null)
    local TRACE=$(traceroute -n -m 2 -q 1 -w 2 8.8.8.8 2>/dev/null | tail -n +2 | head -2 | awk '{print $2}' | tr '\n' ' > ')
    local HINT="Unknown"
    echo "$TRACE" | grep -q "^10\." && HINT="Private LAN (10.x)"
    echo "$TRACE" | grep -q "^192\.168\." && HINT="Home LAN"
    echo "$TRACE" | grep -q "^172\.1[6-9]\." && HINT="Private LAN (172.x)"
    [ -z "$TRACE" ] && HINT="No internet route"
    echo "Network: $HINT ($IFACE, gw: $GATEWAY)" | tee "$CACHE_FILE"
}

print_warning "$(resolve_identity)"
print_status "$(detect_network)"

# =============================================================================
# 2. Gather staged markdown files
# =============================================================================
STAGED=$(git diff --cached --name-only)
[ -z "$STAGED" ] && print_warning "No staged files to validate" && exit 0

# =============================================================================
# 3-7. Validation helpers
# =============================================================================
get_frontmatter() { awk 'BEGIN{c=0} /^---$/{c++; next} c==1{print} c==2{exit}' "$1"; }

validate_assigned_to() {
    local FILE=$1 TYPE=$2 FM=$(get_frontmatter "$FILE")
    [ -z "$FM" ] && return 0
    local ASSIGNED=$(echo "$FM" | python3 -c "import sys,yaml; fm=yaml.safe_load(sys.stdin); a=fm.get('assigned_to',[]); print(a[0]) if a and len(a)>0 else None" 2>/dev/null)
    [ "$TYPE" = "proposal" ] && echo "$FM" | grep -q "^approved: true" && { [ -z "$ASSIGNED" ] && print_warning "$FILE: Approved but assigned_to empty!" && return 0; }
    if [ "$TYPE" = "plan" ]; then
        local STATUS=$(echo "$FM" | grep "^status:" | sed 's/^status: *//')
        if echo "$STATUS" | grep -qE '^(approved|in-progress)$' && { [ -z "$ASSIGNED" ] || [ "$ASSIGNED" = "None" ]; }; then
            print_error "$FILE: status=$STATUS but assigned_to empty!"; return 1
        fi
    fi
    return 0
}

validate_automated() {
    local FILE=$1; [[ ! "$FILE" =~ ^plans/[^/]+\.md$ ]] || [[ "$FILE" =~ ^plans/completed/ ]] && return 0
    local FM=$(get_frontmatter "$FILE"); [ -z "$FM" ] && return 0
    local AUTO=$(echo "$FM" | grep "^automated:" | sed 's/^automated: *//' | tr -d ' ')
    [ -n "$AUTO" ] && [ "$AUTO" != "off" ] && [ "$AUTO" != "guided" ] && [ "$AUTO" != "full" ] && print_error "$FILE: automated must be off|guided|full (got: $AUTO)" && return 1
    return 0
}

validate_template_vars() {
    local FILE=$1; [[ ! "$FILE" =~ ^docs/ ]] && [[ ! "$FILE" =~ ^plans/[^/]+\.md$ ]] && return 0
    grep -qE '\{\{VALUE:|DATE:YYYY' "$FILE" 2>/dev/null && print_error "$FILE: Unresolved template variables!" && return 1
    return 0
}

validate_scenario_synthesis() {
    local FILE=$1; [[ ! "$FILE" =~ ^plans/[^/]+\.md$ ]] || [[ "$FILE" =~ ^plans/completed/ ]] && return 0
    local CONTENT=$(cat "$FILE" 2>/dev/null)
    echo "$CONTENT" | grep -qiE '\b(bash|shell|script|sed|awk|python|deploy|generator|pipeline)\b|batch.*edit' || return 0
    local FM=$(get_frontmatter "$FILE"); local STATUS=$(echo "$FM" | grep "^status:" | sed 's/^status: *//')
    echo "$STATUS" | grep -qE '^(approved|in-progress)$' || return 0
    echo "$FM" | grep -q "^scenario_synthesis:" && return 0
    print_error "$FILE: Involves automation but missing scenario_synthesis!"; return 1
}

validate_agent_instructions() {
    local FILE=$1; [[ ! "$FILE" =~ ^docs/SOPs/ ]] && return 0
    grep -q '<agent-instructions' "$FILE" 2>/dev/null || { print_warning "$FILE: SOP missing Agent Instructions section"; return 0; }
    grep -q '</agent-instructions>' "$FILE" 2>/dev/null || { print_error "$FILE: Agent Instructions tag unclosed!"; return 1; }
    grep -q 'triggers=' "$FILE" 2>/dev/null || { print_warning "$FILE: Agent Instructions missing triggers attribute"; return 0; }
    return 0
}

# =============================================================================
# Layer 3 — Lifecycle compliance checks
# =============================================================================

# Detect self-approval: proposal newly gaining approved: true without HUMAN_APPROVED=1
validate_self_approval() {
    local FILE=$1
    [[ ! "$FILE" =~ ^proposals/approved/ ]] && return 0
    local NEW_FM=$(get_frontmatter "$FILE")
    local NEW_APPROVED=$(echo "$NEW_FM" | grep "^approved:" | sed 's/^approved: *//')
    [ "$NEW_APPROVED" != "true" ] && return 0

    # Check if approved was already true in the committed version (editing, not approving)
    local OLD_APPROVED=$(git show HEAD:"$FILE" 2>/dev/null | awk 'BEGIN{c=0} /^---$/{c++; next} c==1{print} c==2{exit}' | grep "^approved:" | sed 's/^approved: *//')
    [ "$OLD_APPROVED" = "true" ] && return 0  # already approved, just editing

    # Newly approved file — requires explicit human authorization
    if [ -z "$HUMAN_APPROVED" ]; then
        print_error "$FILE: 'approved' set to true — only humans may approve proposals"
        print_error "  If intentional: HUMAN_APPROVED=1 git commit ..."
        return 1
    fi
    # Human-authorized: log it
    print_status "$FILE: human-approved (HUMAN_APPROVED=1)"
    return 0
}

# Detect plan status advancing to in-progress/completed without completed_date where required
# Also enforces the two-step gate: completed requires gate_status:approved
validate_plan_transition() {
    local FILE=$1
    [[ ! "$FILE" =~ ^plans/ ]] && return 0
    local FM=$(get_frontmatter "$FILE")
    local STATUS=$(echo "$FM" | grep "^status:" | sed 's/^status: *//')

    if [ "$STATUS" = "completed" ]; then
        # Must have completed_date
        echo "$FM" | grep -q "^completed_date:" || { print_error "$FILE: status=completed but missing completed_date"; return 1; }
        # Must have gate_status:approved — prevents skipping the gate review
        local GATE=$(echo "$FM" | grep "^gate_status:" | sed 's/^gate_status: *//')
        if [ -n "$GATE" ] && [ "$GATE" != "approved" ] && [ "$GATE" != "waived" ]; then
            print_error "$FILE: status=completed but gate_status='$GATE' — gate must be approved or waived by a human before marking complete"
            print_error "  1. Human reviews the plan"
            print_error "  2. Human sets gate_status: approved (with HUMAN_APPROVED=1)"
            print_error "  3. Then status: completed can be committed"
            return 1
        fi
        # Require HUMAN_APPROVED for completion
        [ "$HUMAN_APPROVED" = "1" ] || { print_error "$FILE: status=completed requires HUMAN_APPROVED=1 — only humans complete plans"; return 1; }
    fi

    if [ "$STATUS" = "canceled" ]; then
        echo "$FM" | grep -q "^canceled_date:" || { print_error "$FILE: status=canceled but missing canceled_date"; return 1; }
        echo "$FM" | grep -q "^cancellation_reason:" || { print_warning "$FILE: status=canceled but missing cancellation_reason"; }
        [ "$HUMAN_APPROVED" = "1" ] || { print_error "$FILE: status=canceled requires HUMAN_APPROVED=1"; return 1; }
    fi

    # Block gate_status:approved without HUMAN_APPROVED
    local GATE=$(echo "$FM" | grep "^gate_status:" | sed 's/^gate_status: *//')
    if [ "$GATE" = "approved" ] || [ "$GATE" = "waived" ]; then
        [ "$HUMAN_APPROVED" = "1" ] || { print_error "$FILE: gate_status=$GATE requires HUMAN_APPROVED=1 — only humans can sign off phase gates"; return 1; }
    fi

    return 0
}

# Log lifecycle transition to .docwright/lifecycle-audit.jsonl
log_lifecycle_event() {
    local FILE=$1 EVENT=$2
    local AUDIT_DIR="$REPO_ROOT/.docwright"
    local AUDIT_LOG="$AUDIT_DIR/lifecycle-audit.jsonl"
    mkdir -p "$AUDIT_DIR"
    local USER=$(git config user.name 2>/dev/null || echo "unknown")
    local HOST=$(hostname)
    local TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    echo "{\"ts\":\"$TS\",\"event\":\"$EVENT\",\"file\":\"$FILE\",\"user\":\"$USER\",\"host\":\"$HOST\"}" >> "$AUDIT_LOG"
}

# =============================================================================
# Main validation loop
# =============================================================================
ERRORS=0; WARNINGS=0
for FILE in $STAGED; do
    [[ ! "$FILE" =~ \.md$ ]] && continue
    validate_template_vars "$FILE" || ((ERRORS++))
    [[ "$FILE" =~ ^plans/[^/]+\.md$ ]] && [[ ! "$FILE" =~ ^plans/completed/ ]] && { validate_automated "$FILE" || ((ERRORS++)); }
    [[ "$FILE" =~ ^proposals/approved/ ]] && {
        validate_assigned_to "$FILE" "proposal" || ((ERRORS++))
        validate_self_approval "$FILE" || ((ERRORS++))
    }
    if [[ "$FILE" =~ ^plans/ ]]; then
        validate_plan_transition "$FILE" || ((ERRORS++))
        if [[ "$FILE" =~ ^plans/[^/]+\.md$ ]] && [[ ! "$FILE" =~ ^plans/completed/ ]]; then
            validate_assigned_to "$FILE" "plan" || ((ERRORS++))
            validate_scenario_synthesis "$FILE" || ((ERRORS++))
        fi
    fi
    [[ "$FILE" =~ ^docs/SOPs/ ]] && { validate_agent_instructions "$FILE" || ((ERRORS++)); }
    # Audit log — record any lifecycle file change
    if [[ "$FILE" =~ ^(proposals|plans|docs)/ ]]; then
        log_lifecycle_event "$FILE" "staged"
    fi
done

# ── Pending steps enforcement (single Node.js call for all staged plan files) ──
STAGED_PLANS=""
for FILE in $STAGED; do
    [[ "$FILE" =~ ^plans/[^/]+\.md$ ]] && [[ ! "$FILE" =~ ^plans/completed/ ]] && STAGED_PLANS="$STAGED_PLANS $FILE"
done
if [ -n "$STAGED_PLANS" ] && command -v node &>/dev/null; then
    if ! node scripts/lifecycle-gate.js --check-files $STAGED_PLANS 2>&1; then
        ((ERRORS++))
    fi
fi

# ── Auto-version bump ──────────────────────────────────────────────────────
# If any staged plan file is being set to status: completed, recalculate
# and update VERSION + package.json, then stage both.
PLAN_COMPLETED=0
for FILE in $STAGED; do
    [[ ! "$FILE" =~ ^plans/[^/]+\.md$ ]] && continue
    STATUS=$(git show ":$FILE" 2>/dev/null | grep "^status:" | head -1 | sed 's/^status:[[:space:]]*//')
    [[ "$STATUS" == "completed" ]] && PLAN_COMPLETED=1 && break
done

if [ $PLAN_COMPLETED -eq 1 ] && command -v node &>/dev/null; then
    NEW_VERSION=$(node scripts/version.js --update 2>/dev/null)
    if [ -n "$NEW_VERSION" ]; then
        git add VERSION 2>/dev/null
        git add src/webui/package.json 2>/dev/null
        git add package.json 2>/dev/null
        print_status "Version bumped to $NEW_VERSION"
    fi
fi

[ $ERRORS -gt 0 ] && print_error "Pre-commit validation failed with $ERRORS error(s)" && exit 1
[ $WARNINGS -gt 0 ] && print_warning "Pre-commit validation passed with $WARNINGS warning(s)"
print_status "Pre-commit validation passed"
exit 0
