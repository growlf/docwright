# DocWright — container runtime configuration (production image)
#
# Copy to `app.env` next to docker-compose.prod.yml and fill in. Loaded VERBATIM
# via env_file (values are NOT interpolated), so a bcrypt hash's $ survives.
# Everything has a safe in-image default — an empty/absent app.env still boots
# (AUTH_MODE=none, no AI backend). Put ONLY container config here; the host port,
# vault path, and image ref live in `.env` (see docker-compose.prod.yml header).
#
# ── Authentication ────────────────────────────────────────────────────────────
# AUTH_MODE: none (default, open) | local (username/password) | forgejo (OAuth)
AUTH_MODE=none
# For AUTH_MODE=local — LOCAL_AUTH_PASSWORD is a BCRYPT HASH (generate with bcrypt):
LOCAL_AUTH_USER=
LOCAL_AUTH_PASSWORD=
LOCAL_AUTH_EMAIL=
LOCAL_AUTH_DISPLAY_NAME=
SESSION_TTL_SECONDS=86400
# For AUTH_MODE=forgejo:
FORGEJO_URL=
FORGEJO_CLIENT_ID=
FORGEJO_CLIENT_SECRET=

# ── Origin / reverse proxy (REQUIRED for form POSTs like login) ────────────────
# The production server (adapter-node) rejects cross-origin form submissions
# unless it knows its own origin. REQUIRED once AUTH_MODE != none (login is a
# form POST). Leave these UNSET (commented) for an open AUTH_MODE=none instance.
# IMPORTANT: do NOT set ORIGIN to an empty string — adapter-node rejects "" and
# refuses to start. Either set a real URL or leave the line commented.
# Set ONE of:
#   ORIGIN — the exact URL users hit for DIRECT access:
# ORIGIN=https://docs.example.org
#   ...OR, when behind a reverse proxy that sets forwarded headers:
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host

# ── Git identity + push credentials ────────────────────────────────────────────
GIT_USER_NAME=DocWright User
GIT_USER_EMAIL=docwright@localhost
# HTTPS push token (alternative: mount an SSH key at /root/.ssh/id_ed25519):
GIT_TOKEN=

# ── AI backend (OpenCode) ──────────────────────────────────────────────────────
# URL where `opencode serve` is reachable FROM THE CONTAINER (never browser-exposed):
OPENCODE_URL=
OPENCODE_SERVER_USERNAME=
OPENCODE_SERVER_PASSWORD=
# OPENCODE_DEFAULT_MODEL=

# ── Behavior (optional) ────────────────────────────────────────────────────────
# DOCWRIGHT_PROFILE=org-operations
# DOCWRIGHT_LOG_LEVEL=info
# Per-surface live-AI escape hatches (default ON): set to 0/false/off to revert
# a surface to the legacy blocking render.
# LIVE_AI_REVIEW=1
# LIVE_AI_IMPROVE=1
# LIVE_AI_EXECUTOR=1
# LIVE_AI_CHAT=1
