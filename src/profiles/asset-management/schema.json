{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocWright Profile Schema — asset-management",
  "description": "Frontmatter validation schema for document types in this profile. Each key in documentTypes is a document type name; its value is a JSON Schema object.",
  "documentTypes": {
    "device": {
      "description": "A physical or virtual asset tracked in the network inventory.",
      "required": ["title", "type", "status", "hostname", "author-role"],
      "properties": {
        "title": {"type": "string", "description": "Device hostname or display name"},
        "type": {
          "type": "string",
          "enum": ["device", "bmc", "network-segment", "vlan", "ipam", "service", "connection", "rack"]
        },
        "status": {
          "type": "string",
          "enum": ["discovered", "provisioning", "active", "maintenance", "decommissioned", "retired"]
        },
        "hostname": {"type": "string", "description": "Short hostname (e.g. pve2)"},
        "ip": {"type": "string", "description": "Primary IPv4 address"},
        "mac": {"type": "string", "description": "Primary MAC address (uppercase, colon-separated)"},
        "author-role": {"type": "string", "default": "contributor"},
        "manufacturer": {"type": "string"},
        "model": {"type": "string"},
        "serial": {"type": "string"},
        "os": {"type": "string"},
        "parent": {"type": "string", "description": "Hostname of parent/container device"},
        "manages": {"type": "string", "description": "Hostname of managed device (BMC→server)"},
        "peers": {"type": "array", "items": {"type": "string"}, "description": "Peer device hostnames"},
        "member_of": {"type": "array", "items": {"type": "string"}, "description": "Group/cluster memberships"},
        "provides": {"type": "array", "items": {"type": "string"}, "description": "Service exports"},
        "last_host": {"type": "string", "description": "Last known hosting server"},
        "_provenance": {
          "type": "object",
          "properties": {
            "scanned": {"type": "string", "format": "date-time"},
            "source": {"type": "string", "enum": ["manual", "hardware-audit", "ansible-facts", "arp-table", "dhcp-leases"]},
            "corroborations": {"type": "array", "items": {"type": "string"}},
            "maturity": {"type": "string", "enum": ["L1", "L2", "L3"]}
          }
        }
      }
    },
    "research": {
      "description": "A structured investigation into a question or decision area. Captured in research/ directory.",
      "required": ["title", "status", "question", "author", "created", "author-role"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "status": {
          "type": "string",
          "enum": ["active", "concluded", "archived"]
        },
        "question": {
          "type": "string",
          "minLength": 1,
          "description": "One-sentence research question this document investigates"
        },
        "conclusion": {
          "type": "string",
          "enum": ["open", "recommends", "inconclusive", "superseded"],
          "description": "Required when status: concluded"
        },
        "author": {"type": "string", "minLength": 1},
        "created": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "author-role": {"type": "string", "default": "contributor"},
        "tags": {"type": "array", "items": {"type": "string"}},
        "linked_proposals": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Proposals that this research informed"
        },
        "related_research": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Other research documents on adjacent questions"
        }
      },
      "if": {
        "properties": {"status": {"const": "concluded"}},
        "required": ["status"]
      },
      "then": {"required": ["conclusion"]}
    }
  }
}
