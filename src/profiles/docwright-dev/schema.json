{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocWright Profile Schema — docwright-dev",
  "description": "Frontmatter validation schema for DocWright self-development document types. Each key in documentTypes is a document type name; its value is a JSON Schema object. The core distinction: code-issue/bug deliverables are diffs (closed by a PR); proposal/plan/policy/decision are durable governance.",
  "documentTypes": {
    "code-issue": {
      "description": "A unit of DocWright product work whose deliverable is a diff, closed by a PR. Stored in issues/.",
      "required": ["title", "status", "created", "author", "author-role"],
      "properties": {
        "title":            { "type": "string", "minLength": 1 },
        "status":           { "type": "string", "enum": ["open", "in-progress", "resolved", "wont-fix"] },
        "created":          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "author":           { "type": "string", "minLength": 1 },
        "author-role":      { "type": "string", "default": "contributor" },
        "category":         { "type": "string", "enum": ["feature", "bug", "chore", "refactor", "test", "docs"] },
        "priority":         { "type": "string", "enum": ["low", "medium", "high"] },
        "complexity":       { "type": "string", "enum": ["low", "medium", "high"] },
        "estimated_effort": { "type": "string", "enum": ["XS", "S", "M", "L", "XL"] },
        "closed_by_pr":     { "type": "string", "description": "PR number/URL that closes this code-issue" },
        "cross_link":       { "type": "string", "description": "Governance doc (proposal/policy/decision) this code-issue implements" },
        "milestone":        { "type": "string", "description": "Milestone id, or the literal 'future'. Every open item carries one (lint-enforced)." },
        "channel":          { "type": "string", "enum": ["dev", "beta", "stable"], "default": "dev" },
        "tags":             { "type": "array", "items": { "type": "string" } }
      }
    },
    "bug": {
      "description": "A code-issue whose category is a defect. Deliverable is a diff. Stored in issues/.",
      "required": ["title", "status", "created", "author", "author-role"],
      "properties": {
        "title":            { "type": "string", "minLength": 1 },
        "status":           { "type": "string", "enum": ["open", "in-progress", "resolved", "wont-fix"] },
        "created":          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "author":           { "type": "string", "minLength": 1 },
        "author-role":      { "type": "string", "default": "contributor" },
        "category":         { "type": "string", "const": "bug" },
        "priority":         { "type": "string", "enum": ["low", "medium", "high"] },
        "complexity":       { "type": "string", "enum": ["low", "medium", "high"] },
        "estimated_effort": { "type": "string", "enum": ["XS", "S", "M", "L", "XL"] },
        "closed_by_pr":     { "type": "string" },
        "cross_link":       { "type": "string" },
        "milestone":        { "type": "string", "description": "Milestone id, or the literal 'future'. Every open item carries one (lint-enforced)." },
        "channel":          { "type": "string", "enum": ["dev", "beta", "stable"], "default": "dev" },
        "tags":             { "type": "array", "items": { "type": "string" } }
      }
    },
    "proposal": {
      "description": "A governance proposal — a durable rule/decision/spec that outlives any single diff. Stored in proposals/.",
      "required": ["title", "author", "author-role", "created", "approved"],
      "properties": {
        "title":            { "type": "string", "minLength": 1 },
        "author":           { "type": "string", "minLength": 1 },
        "author-role":      { "type": "string", "default": "contributor" },
        "created":          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "approved":         { "type": "boolean", "description": "Human-only. AI may never set this true." },
        "category":         { "type": "array", "items": { "type": "string" } },
        "priority":         { "type": "string", "enum": ["low", "medium", "high"] },
        "complexity":       { "type": "string", "enum": ["low", "medium", "high"] },
        "cross_link":       { "type": "string", "description": "code-issue(s) that implement this proposal" },
        "tags":             { "type": "array", "items": { "type": "string" } }
      }
    },
    "plan": {
      "description": "An execution plan for delivering an approved proposal. Stored in plans/.",
      "required": ["title", "status", "created", "author", "author-role"],
      "properties": {
        "title":            { "type": "string", "minLength": 1 },
        "status":           { "type": "string", "enum": ["draft", "approved", "in-progress", "completed", "canceled"] },
        "created":          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "author":           { "type": "string", "minLength": 1 },
        "author-role":      { "type": "string", "default": "contributor" },
        "proposal_source":  { "type": "string", "description": "Path to the approved proposal this plan delivers" },
        "priority":         { "type": "string", "enum": ["low", "medium", "high"] },
        "phase":            { "type": "integer" },
        "milestone":        { "type": "string", "description": "Milestone id, or the literal 'future'. Every open item carries one (lint-enforced)." },
        "channel":          { "type": "string", "enum": ["dev", "beta", "stable"], "default": "dev" },
        "parent_plan":      { "type": "string" },
        "tags":             { "type": "array", "items": { "type": "string" } }
      }
    },
    "policy": {
      "description": "A durable organizational rule. Stored in policies/.",
      "required": ["title", "status", "created", "author", "author-role"],
      "properties": {
        "title":            { "type": "string", "minLength": 1 },
        "status":           { "type": "string", "enum": ["draft", "active", "superseded", "archived"] },
        "created":          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "author":           { "type": "string", "minLength": 1 },
        "author-role":      { "type": "string", "default": "contributor" },
        "superseded_by":    { "type": "string" },
        "tags":             { "type": "array", "items": { "type": "string" } }
      }
    },
    "decision": {
      "description": "A recorded decision (ADR-style). Stored in decisions/.",
      "required": ["title", "status", "created", "author", "author-role"],
      "properties": {
        "title":            { "type": "string", "minLength": 1 },
        "status":           { "type": "string", "enum": ["draft", "final"] },
        "created":          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "author":           { "type": "string", "minLength": 1 },
        "author-role":      { "type": "string", "default": "contributor" },
        "supersedes":       { "type": "string" },
        "tags":             { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
