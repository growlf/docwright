# Copy to .env and adjust for your environment.
# The DocWright launcher (~/local/bin/DocWright) sets these automatically
# when starting Vite. You only need this file if running Vite manually.

# URL of your OpenCode serve instance (started by the DocWright launcher)
OPENCODE_URL=http://localhost:4096

# Absolute path to the DocWright vault root (default: ../../ from src/webui)
# DOCWRIGHT_ROOT=/home/youruser/Projects/DocWright

# ── Authentication ─────────────────────────────────────────────────────────────
# AUTH_MODE controls which auth provider is active.
#   none    — no authentication (single-user local dev, default)
#   local   — username + password from LOCAL_AUTH_USER / LOCAL_AUTH_PASSWORD
#   forgejo — Forgejo OAuth (recommended for shared deployments)
AUTH_MODE=none

# Session TTL in seconds (default: 86400 = 24 hours).
SESSION_TTL_SECONDS=86400

# ── Forgejo OAuth (AUTH_MODE=forgejo) ──────────────────────────────────────────
FORGEJO_URL="https://git.example.com"
FORGEJO_CLIENT_ID=""
FORGEJO_CLIENT_SECRET=""

# ── Local auth (AUTH_MODE=local) ───────────────────────────────────────────────
# LOCAL_AUTH_PASSWORD must be a bcrypt hash. Generate with:
#   node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
LOCAL_AUTH_USER=admin
LOCAL_AUTH_PASSWORD=""
LOCAL_AUTH_EMAIL="admin@localhost"
LOCAL_AUTH_DISPLAY_NAME="Admin"

# ── Dev identity (AUTH_MODE=none, used for git attribution) ────────────────────
# LOCAL_AUTH_USER / LOCAL_AUTH_EMAIL / LOCAL_AUTH_DISPLAY_NAME also set the
# synthetic dev user when AUTH_MODE=none, so git commits are attributed correctly.
