# Copy to .env and adjust for your environment.
# The DocWright launcher (~/local/bin/DocWright) sets these automatically
# when starting Vite. You only need this file if running Vite manually.

# URL of your OpenCode serve instance (started by the DocWright launcher)
OPENCODE_URL=http://localhost:4096

# Absolute path to the DocWright vault root (default: ../../ from src/webui)
# DOCWRIGHT_ROOT=/home/youruser/Projects/DocWright
